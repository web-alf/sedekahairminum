---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
const stats = [
  { num: 1, suffix: '', label: 'Kabupaten' },
  { num: 19, suffix: '', label: 'Lembaga Penerima' },
  { num: 298, suffix: '', label: 'Galon/Distribusi' },
  { num: 7, suffix: '', label: 'Kecamatan' },
];

const penerima = [
  { name: 'PP An-Nur', type: 'Pesantren', city: 'Karangmojo', province: 'Gunung Kidul', galon: 6 },
  { name: "PP Fajrussa'adah", type: 'Pesantren', city: 'Wonosari', province: 'Gunung Kidul', galon: 8 },
  { name: 'PP KI Ageng Wonokusumo', type: 'Pesantren', city: 'Karangmojo', province: 'Gunung Kidul', galon: 6 },
  { name: 'PP Al-Kholifah', type: 'Pesantren', city: 'Paliyan', province: 'Gunung Kidul', galon: 5 },
  { name: 'PP Al-Murtadlo', type: 'Pesantren', city: 'Ponjong', province: 'Gunung Kidul', galon: 10 },
  { name: 'PP Al-Hikmah Gubuk Rubuh', type: 'Pesantren', city: 'Playen', province: 'Gunung Kidul', galon: 8 },
  { name: "PP Ar-Ruhamaa'", type: 'Pesantren', city: 'Playen', province: 'Gunung Kidul', galon: 10 },
  { name: 'Pondok Nurul Jamil Al-Jumar', type: 'Pesantren', city: 'Wonosari', province: 'Gunung Kidul', galon: 6 },
  { name: 'PP Nurulhadi 2', type: 'Pesantren', city: 'Playen', province: 'Gunung Kidul', galon: 2 },
  { name: 'PP Ash-Shiddiq 2', type: 'Pesantren', city: 'Ngawen', province: 'Gunung Kidul', galon: 8 },
  { name: 'PP Hidayatul Mubtadiin Kunci', type: 'Pesantren', city: 'Panggang', province: 'Gunung Kidul', galon: 5 },
  { name: 'PP & Islamic Center Yasma Mulia', type: 'Pesantren', city: 'Wonosari', province: 'Gunung Kidul', galon: 4 },
  { name: 'PP Roudlotuth Tholabah', type: 'Pesantren', city: 'Paliyan', province: 'Gunung Kidul', galon: 2 },
  { name: 'PP Kun Solihan', type: 'Pesantren', city: 'Playen', province: 'Gunung Kidul', galon: 6 },
  { name: 'Yayasan Panti Asuhan Islam', type: 'Yayasan', city: 'Playen', province: 'Gunung Kidul', galon: 14 },
  { name: 'PP Thoriqul Mukminin', type: 'Pesantren', city: 'Semanu', province: 'Gunung Kidul', galon: 20 },
  { name: 'PP Baitul Jannah Darussalam', type: 'Pesantren', city: 'Wonosari', province: 'Gunung Kidul', galon: 6 },
  { name: 'PP Assalafiyah Darussalam', type: 'Pesantren', city: 'Wonosari', province: 'Gunung Kidul', galon: 5 },
  { name: 'PP Muhammadiyah Al-Mujahidin', type: 'Pesantren', city: 'Playen', province: 'Gunung Kidul', galon: 10 },
];

const totalGalon = penerima.reduce((s, p) => s + p.galon, 0);
const types = ['Semua', 'Pesantren', 'Yayasan'];
---

<Layout
  title="Data Penerima Manfaat — Sedekah Air Minum"
  description="Daftar lembaga penerima manfaat program Sedekah Air Minum. Lihat data penyaluran air bersih ke masjid, pesantren, dan sekolah Islam di seluruh Indonesia."
>
  <Nav />
  <main>
    <section class="page-hero">
      <div class="container">
        <span class="page-hero__eyebrow">Data Penerima Manfaat</span>
        <h1 class="page-hero__title">Setiap nama,<br/><em>setiap tetes</em> tercatat.</h1>
        <p class="page-hero__intro">
          Daftar lembaga yang telah menerima manfaat program Sedekah Air Minum. Transparansi adalah salah satu pilar utama kami.
        </p>
      </div>
    </section>

    <section class="section" style="padding-top:0">
      <div class="container">
        <div class="penerima-stats">
          <div class="statstrip__grid">
            {stats.map(s => (
              <div class="statstrip__cell">
                <div class="statstrip__num" data-count-to={s.num} data-suffix={s.suffix}>
                  0{s.suffix && <small>{s.suffix}</small>}
                </div>
                <div class="statstrip__label">{s.label}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section" style="padding-top:0">
      <div class="container">
        <div class="section-head fade-up">
          <div>
            <span class="eyebrow">Daftar Lembaga</span>
            <h2 style="margin-top:18px">Penyaluran <em class="italic-serif">terbaru</em>.</h2>
          </div>
          <p class="section-head__intro">Daftar 12 penyaluran terakhir. Untuk laporan lengkap, hubungi tim Donor Relations.</p>
        </div>

        <div class="penerima-toolbar fade-up">
          <div class="input-pill">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
            <input id="penerima-search" placeholder="Cari nama lembaga, kota, atau provinsi..." />
          </div>
          <div class="chip-group" id="penerima-filters">
            {types.map(t => (
              <button class:list={['chip', { 'chip--active': t === 'Semua' }]} data-filter={t}>{t}</button>
            ))}
          </div>
        </div>

        <div style="overflow:auto;border-radius:var(--r-md)" class="fade-up">
          <table class="table" id="penerima-table">
            <thead>
              <tr>
                <th>No</th>
                <th>Lembaga Penerima</th>
                <th>Tipe</th>
                <th>Kecamatan</th>
                <th style="text-align:right">Galon</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              {penerima.map((p, i) => (
                <tr data-type={p.type} data-search={`${p.name} ${p.city} ${p.province}`.toLowerCase()}>
                  <td style="font-family:var(--font-mono);font-size:12px;color:var(--ink-muted)">{i + 1}</td>
                  <td style="color:var(--ink-strong);font-weight:500">{p.name}</td>
                  <td>
                    <span class:list={['table__cat', { 'table__cat--p': p.type === 'Pesantren', 'table__cat--m': p.type === 'Yayasan' }]}>{p.type}</span>
                  </td>
                  <td style="color:var(--ink-muted)">{p.city}</td>
                  <td style="text-align:right;font-family:var(--font-mono);color:var(--ink-strong)">{p.galon}</td>
                  <td>
                    <span style="display:inline-flex;align-items:center;gap:6px;font-size:12px;color:#7fe9c4">
                      <span style="width:6px;height:6px;border-radius:50%;background:#7fe9c4"></span>
                      Tersalurkan
                    </span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <div id="penerima-info" style="display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-top:20px;font-size:13px;color:var(--ink-muted)">
          <span>Menampilkan {penerima.length} lembaga penerima</span>
          <span>Total distribusi: <strong style="color:var(--aqua);font-family:var(--font-mono)">{totalGalon} galon</strong></span>
        </div>
      </div>
    </section>

    <section class="section" style="padding-top:0">
      <div class="container">
        <div class="cta-banner fade-up">
          <div>
            <span class="eyebrow">Pengajuan Penerima</span>
            <h2 class="cta-banner__title" style="margin-top:16px">Lembaga Anda<br/>butuh <em>air bersih?</em></h2>
            <p class="cta-banner__desc">Masjid, pesantren, atau sekolah Islam di wilayah Anda kesulitan akses air minum yang layak? Ajukan sebagai penerima manfaat.</p>
          </div>
          <div class="cta-banner__actions">
            <a href="/kontak" class="btn btn--brass btn--lg">
              Ajukan Lembaga
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
            <span style="font-size:13px;color:var(--ink-muted)">Gratis, tanpa biaya administrasi.</span>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .page-hero {
    padding-top: 180px;
    padding-bottom: 96px;
    text-align: center;
  }
  .page-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--aqua);
    margin-bottom: 24px;
  }
  .page-hero__eyebrow::before, .page-hero__eyebrow::after {
    content: "";
    width: 24px;
    height: 1px;
    background: currentColor;
  }
  .page-hero__title {
    font-family: var(--font-display);
    font-size: clamp(48px, 7vw, 88px);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.025em;
    margin: 0 0 24px;
  }
  .page-hero__title em { font-style: italic; color: var(--aqua); }
  .page-hero__intro {
    font-size: clamp(16px, 1.3vw, 19px);
    color: var(--ink-muted);
    max-width: 62ch;
    margin: 0 auto;
    line-height: 1.65;
  }
  .penerima-stats {
    border-radius: var(--r-lg);
    border: 1px solid var(--border);
    background: color-mix(in srgb, var(--surface) 50%, transparent);
    backdrop-filter: blur(10px);
    overflow: hidden;
  }
  .penerima-toolbar {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
    margin-bottom: 28px;
  }
  .input-pill {
    flex: 1;
    min-width: 240px;
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 12px 22px;
  }
  .input-pill input { background: none; border: none; outline: none; font-size: 14px; width: 100%; color: var(--ink); }
  .input-pill svg { color: var(--ink-muted); flex-shrink: 0; }
  .chip-group { display: flex; gap: 6px; flex-wrap: wrap; }
  .chip {
    padding: 10px 18px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 999px;
    font-size: 13px;
    color: var(--ink-muted);
    cursor: pointer;
    transition: all 0.25s var(--ease-out);
  }
  .chip:hover { color: var(--ink); }
  .chip--active { background: var(--aqua); color: #03222a; border-color: var(--aqua); }
  .table {
    width: 100%;
    border-collapse: collapse;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    overflow: hidden;
  }
  .table th, .table td { text-align: left; padding: 18px 24px; font-size: 14px; border-bottom: 1px solid var(--border); }
  .table th { font-weight: 500; font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-dim); background: var(--surface-2); }
  .table tr:last-child td { border-bottom: none; }
  .table tr:hover td { background: color-mix(in srgb, var(--aqua) 5%, transparent); }
  .table__cat { display: inline-block; padding: 4px 10px; border-radius: 6px; font-size: 11px; letter-spacing: 0.05em; text-transform: uppercase; }
  .table__cat--p { background: color-mix(in srgb, var(--brass) 16%, transparent); color: var(--brass); }
  .table__cat--m { background: color-mix(in srgb, var(--aqua) 14%, transparent); color: var(--aqua); }
  .table__cat--s { background: color-mix(in srgb, #84cc88 14%, transparent); color: #84cc88; }
  @media (max-width: 640px) {
    .table { font-size: 12px; }
    .table th, .table td { padding: 10px 12px; }
    .page-hero { padding-top: 140px; padding-bottom: 64px; }
    .page-hero__title { font-size: clamp(36px, 8vw, 48px); }
    .input-pill { min-width: unset; }
    .penerima-toolbar { flex-direction: column; }
    .chip { padding: 8px 14px; font-size: 12px; }
  }
</style>

<script>
  const counters = document.querySelectorAll('[data-count-to]');
  const cio = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el = entry.target as HTMLElement;
      const to = parseFloat(el.dataset.countTo!);
      const suffix = el.dataset.suffix || '';
      const isFloat = to % 1 !== 0;
      const start = performance.now();
      function tick(now: number) {
        const t = Math.min(1, (now - start) / 1600);
        const eased = 1 - Math.pow(1 - t, 3);
        const v = to * eased;
        el.innerHTML = (isFloat ? v.toFixed(1) : Math.round(v).toLocaleString('id-ID')) + (suffix ? `<small>${suffix}</small>` : '');
        if (t < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
      cio.unobserve(el);
    });
  }, { threshold: 0.2 });
  counters.forEach(c => cio.observe(c));

  const search = document.getElementById('penerima-search') as HTMLInputElement;
  const filters = document.querySelectorAll('[data-filter]');
  const rows = document.querySelectorAll('#penerima-table tbody tr') as NodeListOf<HTMLTableRowElement>;
  let activeFilter = 'Semua';

  function filterTable() {
    const q = search.value.toLowerCase();
    let visible = 0;
    rows.forEach(row => {
      const type = row.dataset.type || '';
      const searchText = row.dataset.search || '';
      const matchFilter = activeFilter === 'Semua' || type === activeFilter;
      const matchSearch = !q || searchText.includes(q);
      const show = matchFilter && matchSearch;
      row.style.display = show ? '' : 'none';
      if (show) visible++;
    });
  }

  search?.addEventListener('input', filterTable);
  filters.forEach(btn => {
    btn.addEventListener('click', () => {
      filters.forEach(b => b.classList.remove('chip--active'));
      btn.classList.add('chip--active');
      activeFilter = (btn as HTMLElement).dataset.filter || 'Semua';
      filterTable();
    });
  });
</script>
