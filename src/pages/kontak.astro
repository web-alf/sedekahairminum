---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { supabaseStatic } from '@/lib/supabase/static';
import { getRekening } from '@/lib/supabase/queries/marketing';

const rekening = await getRekening(supabaseStatic);
---

<Layout
  title="Kontak — Sedekah Air Minum"
  description="Hubungi tim Sedekah Air Minum untuk informasi donasi, pengajuan penerima manfaat, atau kemitraan. WhatsApp, email, dan formulir kontak tersedia."
>
  <Nav />
  <main>
    <section class="page-hero">
      <div class="container">
        <span class="page-hero__eyebrow">Kontak Kami</span>
        <h1 class="page-hero__title">Mari berbagi <em>kebaikan</em><br/>melalui sedekah air.</h1>
        <p class="page-hero__intro">
          Punya pertanyaan tentang program kami? Ingin bersedekah dalam jumlah besar? Atau lembaga Anda ingin menjadi penerima manfaat? Tim kami siap mendampingi.
        </p>
      </div>
    </section>

    <section class="section" style="padding-top:24px">
      <div class="container">
        <div class="contact-grid">
          <div class="contact-card fade-up">
            <div>
              <span class="eyebrow">Saluran Cepat</span>
              <h2 style="margin-top:18px;font-size:clamp(28px, 3vw, 40px)">Kami merespons<br/>dalam <em class="italic-serif">1&times;24 jam</em>.</h2>
            </div>

            <div class="contact-item">
              <div class="contact-item__icon">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.2-.7.1-.2.3-.8.9-.9 1.1-.2.2-.3.2-.6.1-.3-.2-1.3-.5-2.4-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.7-.9-2.3-.3-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.5s1.1 2.9 1.2 3.1c.2.2 2.1 3.3 5.2 4.6.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.7-.7 2-1.4.2-.7.2-1.3.2-1.4 0-.1-.3-.2-.6-.3zM12 2C6.5 2 2 6.5 2 12c0 1.8.5 3.5 1.3 5L2 22l5.2-1.4c1.4.8 3.1 1.2 4.8 1.2 5.5 0 10-4.5 10-10S17.5 2 12 2z"/></svg>
              </div>
              <div>
                <div class="contact-item__label">WhatsApp — Administrasi GWS</div>
                <div class="contact-item__value"><a href="https://wa.me/6285319480974?text=Assalamu%27alaikum%2C%20saya%20ingin%20bertanya%20tentang%20program%20Sedekah%20Air%20Minum." target="_blank" rel="noopener noreferrer">+62 853-1948-0974</a></div>
                <div class="contact-item__sub">Senin–Sabtu · 08:00–17:00 WIB</div>
              </div>
            </div>

            <div class="contact-item">
              <div class="contact-item__icon">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 6-10 7L2 6"/></svg>
              </div>
              <div>
                <div class="contact-item__label">Email</div>
                <div class="contact-item__value"><a href="mailto:gerakansumur@gmail.com">gerakansumur@gmail.com</a></div>
                <div class="contact-item__sub">Untuk donasi korporat & kemitraan</div>
              </div>
            </div>

            <div class="contact-item">
              <div class="contact-item__icon">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <div class="contact-item__label">Alamat Kantor</div>
                <div class="contact-item__value">Karang Duwet II, Karangrejek</div>
                <div class="contact-item__sub">Kec. Wonosari, Kab. Gunung Kidul, DI Yogyakarta</div>
              </div>
            </div>

            <div class="contact-item">
              <div class="contact-item__icon">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              </div>
              <div>
                <div class="contact-item__label">Jam Operasional</div>
                <div class="contact-item__value">Senin – Sabtu · 08:00 – 17:00 WIB</div>
                <div class="contact-item__sub">Tutup pada hari Minggu & libur nasional</div>
              </div>
            </div>
          </div>

          <div class="fade-up" style="transition-delay:120ms">
            <form class="form" id="contact-form">
              <div style="position:absolute;left:-9999px" aria-hidden="true">
                <input type="text" name="website" id="hp-field" tabindex="-1" autocomplete="off" />
              </div>
              <div style="margin-bottom:8px">
                <span class="eyebrow">Kirim Pesan</span>
                <h3 style="margin-top:14px;font-size:26px;font-weight:400">Tulis pesan Anda</h3>
              </div>
              <div class="form__row form__row--double">
                <div class="form__row">
                  <label for="nama">Nama Lengkap</label>
                  <input id="nama" name="nama" required placeholder="Ahmad Hidayat" />
                </div>
                <div class="form__row">
                  <label for="phone">No. WhatsApp</label>
                  <input id="phone" name="phone" required placeholder="0812-xxxx-xxxx" />
                </div>
              </div>
              <div class="form__row">
                <label for="email">Email</label>
                <input id="email" name="email" type="email" placeholder="nama@email.com" />
              </div>
              <div class="form__row">
                <label for="topik">Topik</label>
                <select id="topik" name="topik" required>
                  <option value="" disabled selected>Pilih topik...</option>
                  <option>Sedekah / Donasi</option>
                  <option>Pengajuan Penerima Manfaat</option>
                  <option>Donasi Korporat</option>
                  <option>Media & Kemitraan</option>
                  <option>Lainnya</option>
                </select>
              </div>
              <div class="form__row">
                <label for="pesan">Pesan</label>
                <textarea id="pesan" name="pesan" required placeholder="Tuliskan pesan Anda di sini..."></textarea>
              </div>
              <button type="submit" class="btn btn--primary" style="align-self:flex-start;margin-top:8px" id="submit-btn">
                Kirim Pesan
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>

    <section class="section" style="padding-top:0">
      <div class="container">
        <div class="section-head fade-up">
          <div>
            <span class="eyebrow">Salurkan Donasi</span>
            <h2 style="margin-top:18px">Rekening <em class="italic-serif">resmi</em> kami</h2>
          </div>
          <p class="section-head__intro">
            Semua donasi akan tercatat dan tersalurkan. Konfirmasi setelah transfer ke WhatsApp kami untuk mendapatkan nomor resi pengiriman.
          </p>
        </div>
        <div class="rek-grid">
          {rekening.map(r => (
            <div class="rek-card fade-up">
              <div class="rek-label-corner">{r.label}</div>
              <div style="font-size:11px;letter-spacing:0.18em;text-transform:uppercase;color:var(--ink-dim)">{r.bank}</div>
              <div class="rek-number">
                <span style="font-family:var(--font-mono);font-size:22px;color:var(--ink-strong);letter-spacing:0.04em">{r.no}</span>
                <button class="rek-copy" data-copy={r.no} aria-label={`Salin nomor rekening ${r.label}`} type="button">
                  <svg class="rek-copy__icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                  <svg class="rek-copy__check" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none"><path d="M20 6L9 17l-5-5"/></svg>
                </button>
              </div>
              <div style="margin-top:14px;font-size:13px;color:var(--ink-muted)">a.n. YAYASAN GERAKAN WAKAF SUMUR</div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; }
  .contact-card { display: flex; flex-direction: column; gap: 24px; }
  .contact-item {
    display: grid;
    grid-template-columns: 44px 1fr;
    gap: 20px;
    align-items: start;
    padding: 24px 0;
    border-top: 1px solid var(--border);
  }
  .contact-item:last-of-type { border-bottom: 1px solid var(--border); }
  .contact-item__icon {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--aqua) 12%, transparent);
    color: var(--aqua);
    display: grid;
    place-items: center;
  }
  .contact-item__label { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-dim); margin-bottom: 6px; }
  .contact-item__value { font-size: 16px; color: var(--ink-strong); font-weight: 500; }
  .contact-item__sub { font-size: 13px; color: var(--ink-muted); margin-top: 4px; }
  .form {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    padding: clamp(28px, 4vw, 48px);
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .form__row { display: grid; gap: 8px; }
  .form__row label { font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-dim); }
  .form__row input, .form__row textarea, .form__row select {
    width: 100%;
    padding: 14px 18px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--r-sm);
    font-size: 15px;
    color: var(--ink);
    outline: none;
    transition: border-color 0.25s;
  }
  .form__row input:focus, .form__row textarea:focus, .form__row select:focus { border-color: var(--aqua); }
  .form__row textarea { resize: vertical; min-height: 120px; }
  .form__row--double { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .rek-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .rek-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    padding: 32px;
    position: relative;
    overflow: hidden;
  }
  .rek-label-corner {
    position: absolute;
    top: 24px;
    right: 24px;
    font-family: var(--font-display);
    font-style: italic;
    color: var(--aqua);
    opacity: 0.45;
    font-size: 22px;
  }
  @media (max-width: 1080px) {
    .contact-grid { grid-template-columns: 1fr; gap: 40px; }
    .rek-grid { grid-template-columns: 1fr; }
  }
  .rek-number {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 14px;
  }
  .rek-copy {
    width: 32px;
    height: 32px;
    border-radius: var(--r-xs);
    border: 1px solid var(--border-strong);
    display: grid;
    place-items: center;
    color: var(--ink-muted);
    cursor: pointer;
    transition: all 0.25s var(--ease-out);
    flex-shrink: 0;
    background: none;
  }
  .rek-copy:hover { border-color: var(--aqua); color: var(--aqua); }
  .rek-copy.copied { border-color: #7fe9c4; color: #7fe9c4; }
  @media (max-width: 640px) {
    .form__row--double { grid-template-columns: 1fr; }
    .rek-number span { font-size: 18px !important; }
  }
</style>

<script is:inline>
  document.querySelectorAll('.rek-copy').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var no = btn.dataset.copy;
      navigator.clipboard.writeText(no).then(function() {
        var icon = btn.querySelector('.rek-copy__icon');
        var check = btn.querySelector('.rek-copy__check');
        btn.classList.add('copied');
        icon.style.display = 'none';
        check.style.display = 'block';
        setTimeout(function() {
          btn.classList.remove('copied');
          icon.style.display = 'block';
          check.style.display = 'none';
        }, 2000);
      });
    });
  });
</script>

<script is:inline>
  var WA_NUMBER = '6285319480974';
  var form = document.getElementById('contact-form');
  var btn = document.getElementById('submit-btn');
  var btnDefault = 'Kirim Pesan <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>';

  function buildWaUrl(nama, topik, pesan) {
    var text = "Assalamu'alaikum, saya " + nama + ".\n\nSaya menghubungi terkait: " + topik + ".\n\n" + pesan + "\n\nTerima kasih. Jazakumullahu khairan.";
    return 'https://wa.me/' + WA_NUMBER + '?text=' + encodeURIComponent(text);
  }

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    if (document.getElementById('hp-field').value) return;

    var nama = form.querySelector('#nama').value.trim();
    var phone = form.querySelector('#phone').value.trim();
    var email = form.querySelector('#email').value.trim();
    var topik = form.querySelector('#topik').value;
    var pesan = form.querySelector('#pesan').value.trim();
    var website = document.getElementById('hp-field').value;

    btn.disabled = true;
    btn.innerHTML = '<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" style="animation:spin 1s linear infinite"><circle cx="12" cy="12" r="10" stroke-dasharray="50" stroke-dashoffset="15"/></svg> Mengirim...';

    fetch('/api/contact', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ nama: nama, phone: phone, email: email, topik: topik, pesan: pesan, website: website }),
    })
    .then(function() {
      window.open(buildWaUrl(nama, topik, pesan), '_blank');
      btn.innerHTML = '<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Terkirim — menuju WhatsApp...';
      btn.disabled = false;
      setTimeout(function() { btn.innerHTML = btnDefault; }, 4000);
    })
    .catch(function() {
      window.open(buildWaUrl(nama, topik, pesan), '_blank');
      btn.innerHTML = btnDefault;
      btn.disabled = false;
    });
  });
</script>
<style>
  @keyframes spin { to { transform: rotate(360deg); } }
</style>
