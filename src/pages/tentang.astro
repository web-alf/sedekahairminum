---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const values = [
  { n: '01', title: 'Amanah', desc: 'Setiap rupiah donasi tercatat, terlapor, dan tersalurkan dengan dokumentasi yang dapat diverifikasi.' },
  { n: '02', title: 'Transparan', desc: 'Sistem tracking real-time, laporan triwulan terbuka, dan keuangan diaudit setiap tahun.' },
  { n: '03', title: 'Profesional', desc: 'Standar kualitas air, sistem operasi armada, dan layanan donatur dikelola dengan disiplin tinggi.' },
  { n: '04', title: 'Berkah', desc: 'Kami percaya setiap tegukan air yang sampai pada hamba Allah adalah jariyah yang terus mengalir.' },
];

const milestones = [
  { year: '2022', title: 'Awal Sebuah Niat', desc: 'Berawal dari keprihatinan terhadap pesantren di Sukabumi yang kekurangan air bersih selama musim kemarau panjang.' },
  { year: '2023', title: 'Unit Pertama Berjalan', desc: 'Modifikasi mobil karoseri pertama dengan tangki stainless steel dan sistem filtrasi RO. Pengiriman perdana ke 12 lembaga di Jawa Barat.' },
  { year: '2024', title: 'Sistem Tracking Online', desc: 'Peluncuran website resmi sedekahairminum.com dengan sistem tracking real-time.' },
  { year: '2025', title: 'Ekspansi Jawa Tengah', desc: 'Penambahan armada kedua memperluas operasional ke Jawa Tengah, DIY, dan Banyumas Raya. Total 19 lembaga penerima manfaat di Gunung Kidul.' },
  { year: '2026', title: 'Indonesia Timur', desc: 'Persiapan armada ketiga untuk menjangkau NTB, NTT, dan Sulawesi Selatan. Target 1.000 lembaga penerima manfaat akhir tahun.' },
];

const team = [
  { name: '', role: 'Founder & Direktur', initials: '?' },
  { name: '', role: 'Operasional Armada', initials: '?' },
  { name: '', role: 'Donor Relations', initials: '?' },
];

const misi = [
  'Menyalurkan air minum layak konsumsi ke 1.000+ lembaga penerima manfaat per tahun.',
  'Membangun sistem distribusi yang transparan, terdokumentasi, dan dapat diverifikasi setiap donatur.',
  'Mengedukasi masyarakat tentang keutamaan wakaf air sebagai sedekah jariyah.',
  'Mengembangkan armada dan tim agar menjangkau seluruh pelosok Indonesia.',
];
---

<Layout
  title="Tentang Kami — Sedekah Air Minum"
  description="Kenali visi, misi, nilai, dan perjalanan Sedekah Air Minum — gerakan wakaf air bersih untuk masjid, pesantren, dan lembaga pendidikan Islam di Indonesia."
>
  <Nav />
  <main>
    <section class="page-hero">
      <div class="container">
        <span class="page-hero__eyebrow">Tentang Kami</span>
        <h1 class="page-hero__title fade-up in">Mengalirkan air,<br/><em>mengalirkan</em> pahala.</h1>
        <p class="page-hero__intro fade-up in" style="transition-delay:120ms">
          Sedekah Air Minum adalah gerakan distribusi air minum untuk pesantren dan tempat ibadah yang lahir dari kepedulian terhadap keterbatasan akses air minum layak. Saat ini, kami telah melayani 19 lembaga di Kabupaten Gunung Kidul.
        </p>
      </div>
    </section>

    <section class="section" style="padding-top:40px">
      <div class="container">
        <div class="tentang-vm fade-up">
          <div>
            <span class="eyebrow">Visi</span>
            <p style="font-family:var(--font-display);font-size:clamp(28px, 3.4vw, 42px);font-weight:400;line-height:1.2;margin-top:18px;color:var(--ink-strong);letter-spacing:-0.015em">
              Menjadi gerakan Sedekah Air Minum <em class="italic-serif">terbesar</em> dan paling tepercaya di Indonesia, hadir untuk umat di mana pun mereka berada.
            </p>
          </div>
          <div>
            <span class="eyebrow">Misi</span>
            <ul style="list-style:none;padding:0;margin:18px 0 0;display:flex;flex-direction:column;gap:18px">
              {misi.map(m => (
                <li style="display:grid;grid-template-columns:28px 1fr;gap:14px;align-items:start;color:var(--ink-muted);font-size:15px;line-height:1.6">
                  <span style="width:24px;height:24px;border-radius:50%;background:color-mix(in srgb, var(--aqua) 14%, transparent);color:var(--aqua);display:grid;place-items:center;margin-top:1px;flex-shrink:0">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                  </span>
                  <span>{m}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-head fade-up">
          <div>
            <span class="eyebrow">Nilai Kami</span>
            <h2 style="margin-top:18px">Empat pilar<br/>yang <em class="italic-serif">memandu</em>.</h2>
          </div>
          <p class="section-head__intro">Nilai-nilai ini bukan sekadar slogan. Mereka adalah ukuran yang kami pegang setiap kali armada bergerak, setiap kali laporan kami susun.</p>
        </div>
        <div class="values-grid fade-up">
          {values.map(v => (
            <div class="value">
              <span class="value__num">&mdash; {v.n}</span>
              <h3 class="value__title">{v.title}</h3>
              <p class="value__desc">{v.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-head section-head--center fade-up">
          <span class="eyebrow">Tim Inti</span>
          <h2 style="margin-top:18px">Orang-orang di balik <em class="italic-serif">setiap tetesan</em></h2>
        </div>
        <div class="team-grid fade-up">
          {team.map(m => (
            <div class="member">
              <div class="member__photo"><span class="member__initials">{m.initials}</span></div>
              <div>
                <h3 class="member__name">{m.name}</h3>
                <div class="member__role">{m.role}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section" style="padding-top:0">
      <div class="container">
        <div class="cta-banner fade-up" style="grid-template-columns:1fr">
          <div>
            <span class="eyebrow">Legalitas</span>
            <h2 class="cta-banner__title" style="margin-top:16px;margin-bottom:24px">Terdaftar, <em>tepercaya</em>, terverifikasi.</h2>
            <div class="legalitas-grid">
              {[
                { l: 'Akta Notaris', v: 'No. 07 / 2022' },
                { l: 'Keputusan Menteri Hukum', v: 'AHU-0009581.AH.01.07' },
                { l: 'NPWP', v: '82.104.853.5-503.000' },
              ].map(x => (
                <div style="border-top:1px solid var(--border);padding-top:18px">
                  <div style="font-size:11px;letter-spacing:0.16em;text-transform:uppercase;color:var(--ink-dim)">{x.l}</div>
                  <div style="font-family:var(--font-mono);font-size:14px;margin-top:6px;color:var(--ink)">{x.v}</div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .tentang-vm { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; }
  .values-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .value {
    padding: 40px 28px;
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .value:last-child { border-right: none; }
  .value__num { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.2em; color: var(--aqua); }
  .value__title { font-family: var(--font-display); font-size: 26px; font-weight: 400; line-height: 1.1; }
  .value__desc { color: var(--ink-muted); font-size: 14px; line-height: 1.6; }
  .milestone-list { display: grid; grid-template-columns: 1fr; gap: 0; }
  .milestone {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 48px;
    padding: 36px 0;
    border-top: 1px solid var(--border);
    align-items: start;
  }
  .milestone:last-child { border-bottom: 1px solid var(--border); }
  .milestone__year { font-family: var(--font-display); font-size: 40px; font-weight: 400; color: var(--aqua); line-height: 1; }
  .milestone__title { font-family: var(--font-display); font-size: 24px; font-weight: 400; margin-bottom: 8px; color: var(--ink-strong); }
  .milestone__desc { color: var(--ink-muted); font-size: 15px; line-height: 1.6; }
  .team-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
  .member { display: flex; flex-direction: column; gap: 16px; }
  .member__photo {
    aspect-ratio: 4 / 5;
    background: linear-gradient(135deg, var(--surface-2), var(--surface-3));
    border-radius: var(--r-md);
    overflow: hidden;
    display: grid;
    place-items: center;
  }
  .member__initials { font-family: var(--font-display); font-size: 64px; font-weight: 400; color: var(--aqua); opacity: 0.65; }
  .member__name { font-family: var(--font-display); font-size: 22px; font-weight: 400; color: var(--ink-strong); }
  .member__role { font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-muted); }
  .legalitas-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; margin-top: 12px; }
  @media (max-width: 1080px) {
    .tentang-vm { grid-template-columns: 1fr; gap: 40px; }
    .values-grid { grid-template-columns: 1fr 1fr; }
    .value { border-right: none; border-bottom: 1px solid var(--border); }
    .team-grid { grid-template-columns: 1fr 1fr; }
    .milestone { grid-template-columns: 1fr; gap: 12px; }
    .legalitas-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .values-grid { grid-template-columns: 1fr; }
    .team-grid { grid-template-columns: 1fr; }
    .milestone__year { font-size: 28px; }
    .member__photo { aspect-ratio: 3 / 4; }
    .value { padding: 28px 20px; }
  }
</style>
