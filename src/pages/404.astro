---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Halaman Tidak Ditemukan — Sedekah Air Minum"
  description="Halaman yang Anda cari tidak ditemukan. Kembali ke beranda Sedekah Air Minum."
>
  <Nav />
  <main id="main-content" class="not-found">
    <div class="container">
      <div class="not-found__content fade-up">
        <div class="not-found__visual">
          <svg class="not-found__drop" viewBox="0 0 120 160" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <defs>
              <linearGradient id="drop-grad" x1="60" y1="0" x2="60" y2="160" gradientUnits="userSpaceOnUse">
                <stop offset="0%" stop-color="var(--aqua)" stop-opacity="0.9"/>
                <stop offset="100%" stop-color="var(--aqua-deep)" stop-opacity="0.6"/>
              </linearGradient>
            </defs>
            <path d="M60 0C60 0 0 90 0 120C0 142.09 26.86 160 60 160C93.14 160 120 142.09 120 120C120 90 60 0 60 0Z" fill="url(#drop-grad)"/>
            <ellipse cx="42" cy="110" rx="14" ry="8" fill="var(--aqua-soft)" opacity="0.25" transform="rotate(-15 42 110)"/>
          </svg>
          <div class="not-found__code">404</div>
        </div>

        <span class="eyebrow">Halaman Tidak Ditemukan</span>
        <h1 class="not-found__title">
          Airnya belum<br/><em>mengalir</em> ke sini.
        </h1>
        <p class="lead not-found__desc">
          Halaman yang Anda cari mungkin telah dipindahkan atau tidak tersedia. Mari kembali dan lanjutkan kebaikan.
        </p>

        <div class="not-found__actions">
          <a href="/" class="btn btn--primary btn--lg">
            Kembali ke Beranda
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a href="/kontak" class="btn btn--ghost btn--lg">Hubungi Kami</a>
        </div>

        <nav class="not-found__links" aria-label="Navigasi cepat">
          <span class="not-found__links-label">Atau kunjungi:</span>
          <a href="/tentang">Tentang Kami</a>
          <a href="/penerima">Penerima Manfaat</a>
          <a href="/kontak">Kontak</a>
        </nav>
      </div>
    </div>

    <div class="not-found__ripples" aria-hidden="true">
      <div class="ripple ripple--1"></div>
      <div class="ripple ripple--2"></div>
      <div class="ripple ripple--3"></div>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .not-found {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding: clamp(120px, 15vw, 180px) 0 var(--section-y);
  }

  .not-found__content {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    position: relative;
    z-index: 1;
  }

  .not-found__visual {
    position: relative;
    margin-bottom: 16px;
  }

  .not-found__drop {
    width: 100px;
    height: auto;
    filter: drop-shadow(0 0 40px rgba(94, 228, 240, 0.3));
    animation: dropFloat 4s var(--ease-in-out) infinite;
  }

  :root[data-theme="light"] .not-found__drop {
    filter: drop-shadow(0 0 40px rgba(8, 145, 178, 0.25));
  }

  @keyframes dropFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }

  .not-found__code {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-mono);
    font-size: 28px;
    font-weight: 500;
    color: var(--bg);
    letter-spacing: 0.08em;
    opacity: 0.7;
  }

  :root[data-theme="light"] .not-found__code {
    color: #fff;
  }

  .not-found__title {
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 400;
    line-height: 1.1;
  }

  .not-found__title em {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--aqua);
  }

  .not-found__desc {
    max-width: 48ch;
    text-align: center;
  }

  .not-found__actions {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 16px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .not-found__links {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-top: 24px;
    font-size: 14px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .not-found__links-label {
    color: var(--ink-dim);
  }

  .not-found__links a {
    color: var(--ink-muted);
    transition: color 0.25s var(--ease-out);
    position: relative;
  }

  .not-found__links a::after {
    content: "";
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--aqua);
    transition: width 0.3s var(--ease-out);
  }

  .not-found__links a:hover {
    color: var(--aqua);
  }

  .not-found__links a:hover::after {
    width: 100%;
  }

  /* Ripple effect at bottom */
  .not-found__ripples {
    position: absolute;
    bottom: 20%;
    left: 50%;
    transform: translateX(-50%);
    pointer-events: none;
  }

  .ripple {
    position: absolute;
    border: 1px solid var(--aqua);
    border-radius: 50%;
    opacity: 0;
    animation: rippleExpand 4s var(--ease-out) infinite;
  }

  .ripple--1 {
    width: 40px;
    height: 20px;
    top: -10px;
    left: -20px;
    animation-delay: 0s;
  }

  .ripple--2 {
    width: 80px;
    height: 40px;
    top: -20px;
    left: -40px;
    animation-delay: 0.8s;
  }

  .ripple--3 {
    width: 120px;
    height: 60px;
    top: -30px;
    left: -60px;
    animation-delay: 1.6s;
  }

  @keyframes rippleExpand {
    0% {
      transform: scale(0.5);
      opacity: 0.5;
    }
    100% {
      transform: scale(3);
      opacity: 0;
    }
  }

  @media (max-width: 640px) {
    .not-found__actions {
      flex-direction: column;
      width: 100%;
    }
    .not-found__actions .btn {
      width: 100%;
    }
    .not-found__links {
      flex-direction: column;
      gap: 12px;
    }
  }
</style>
