---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import StatStrip from '../components/StatStrip.astro';
import Features from '../components/Features.astro';
import Map from '../components/Map.astro';
import Gallery from '../components/Gallery.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import CTABanner from '../components/CTABanner.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Sedekah Air Minum — Gerakan Wakaf Air Bersih untuk Indonesia"
  description="Wakaf air bersih untuk masjid, pesantren, dan lembaga pendidikan Islam di seluruh Indonesia. Sedekah jariyah yang terus mengalir."
>
  <Nav />
  <main id="main-content">
    <Hero />
    <StatStrip />
    <Features />
    <Map />
    <Gallery />
    <Testimonials />
    <FAQ />
    <CTABanner />
  </main>
  <Footer />
</Layout>
