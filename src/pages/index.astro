---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import StatStrip from '../components/StatStrip.astro';
import Features from '../components/Features.astro';
import Map from '../components/Map.astro';
import Gallery from '../components/Gallery.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import CTABanner from '../components/CTABanner.astro';
import Footer from '../components/Footer.astro';
import { getHeroSlides, getStats, getFeatures, getProgramSlides, getGallery, getTestimonials, getFaqs, getPenerima } from '@/lib/supabase/queries/marketing';

const supabase = Astro.locals.supabase;
const [heroSlides, homeStats, features, programSlides, gallery, testimonials, faqs, penerima] = await Promise.all([
  getHeroSlides(supabase),
  getStats(supabase, 'home'),
  getFeatures(supabase),
  getProgramSlides(supabase),
  getGallery(supabase),
  getTestimonials(supabase),
  getFaqs(supabase),
  getPenerima(supabase),
]);

const mapPoints = penerima
  .filter(p => p.lat != null && p.lng != null)
  .map(p => ({ lng: p.lng!, lat: p.lat!, name: p.name, alamat: p.alamat ?? '', galon: p.galon, status: p.status }));

// Legend counts derived from data (was hardcoded "19 lembaga · 298 galon").
const penerimaCount = penerima.length;
const galonTotal = penerima.reduce((sum, p) => sum + (p.galon ?? 0), 0);
---

<Layout
  title="Sedekah Air Minum — Gerakan Wakaf Air Bersih untuk Indonesia"
  rawTitle
  description="Wakaf air bersih untuk masjid, pesantren, dan lembaga pendidikan Islam di seluruh Indonesia. Sedekah jariyah yang terus mengalir."
>
  <Nav overHero />
  <main id="main-content">
    <Hero slides={heroSlides} />
    <StatStrip stats={homeStats} />
    <Features features={features} programSlides={programSlides} />
    <Map points={mapPoints} penerimaCount={penerimaCount} galonTotal={galonTotal} />
    <Gallery slides={gallery} />
    <Testimonials testimonials={testimonials} />
    <FAQ faqs={faqs} />
    <CTABanner />
  </main>
  <Footer />
</Layout>
