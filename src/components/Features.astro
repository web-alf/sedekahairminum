---
interface Props {
  features: { n: string; title: string; descr: string }[];
  programSlides: { src: string; cap: string | null; meta: string | null }[];
}
const { features, programSlides } = Astro.props;
---

<section class="section">
  <div class="container">
    <div class="section-head fade-up">
      <div>
        <span class="eyebrow">Tentang Program</span>
        <h2 style="margin-top:18px">Air bersih,<br/>sampai ke <em class="italic-serif">pelosok</em>.</h2>
      </div>
      <p class="section-head__intro">
        Platform sedekah air minum yang menghubungkan donatur, pengelola dan penerima manfaat dalam misi kebaikan distribusi air minum bersih. Bergabunglah dalam misi mulia menyebarkan air bersih khususnya untuk para santri dan lembaga yang membutuhkan.
      </p>
    </div>

    <div class="feature-grid">
      <div class="feature-list fade-up">
        {features.map(f => (
          <div class="feature">
            <span class="feature__num">{f.n}</span>
            <div>
              <h3 class="feature__title">{f.title}</h3>
              <p class="feature__desc">{f.descr}</p>
            </div>
            <span class="feature__arrow">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7M9 7h8v8"/></svg>
            </span>
          </div>
        ))}
      </div>

      <div class="feature-media fade-up" style="transition-delay:120ms" id="program-slider">
        {programSlides.map((s, i) => (
          <div
            class="program-slide"
            data-program-slide={i}
            style={i === 0 ? `background-image:url(${s.src});background-position:center;background-size:cover;opacity:1` : 'background-position:center;background-size:cover;opacity:0'}
            data-lazy-bg={i > 0 ? s.src : undefined}
          ></div>
        ))}
        <div class="program-slide__overlay"></div>

        <div class="program-slider__dots">
          {programSlides.map((_, i) => (
            <button
              class:list={['program-slider__dot', { 'program-slider__dot--active': i === 0 }]}
              data-program-dot={i}
              aria-label={`Program slide ${i + 1}`}
            ></button>
          ))}
        </div>

        <div class="program-slider__counter">
          <span id="program-counter" style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.2em;color:rgba(255,255,255,0.7)">
            01 / {String(programSlides.length).padStart(2, '0')}
          </span>
        </div>

        <div class="feature-media__caption" style="position:absolute;left:24px;right:24px;bottom:24px;z-index:3;color:#fff;font-family:var(--font-display);font-style:italic;font-size:14px;line-height:1.5">
          <span id="program-cap">"{programSlides[0]?.cap ?? ''}"</span><br/>
          <span id="program-meta" style="opacity:0.7;font-style:normal;font-size:12px;letter-spacing:0.08em;text-transform:uppercase">{programSlides[0]?.meta ?? ''}</span>
        </div>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ programSlides }}>
  var pIdx = 0;
  var pTotal = programSlides.length;
  var pSlides = document.querySelectorAll('[data-program-slide]');
  var pDots = document.querySelectorAll('[data-program-dot]');
  var pCounter = document.getElementById('program-counter');
  var pCap = document.getElementById('program-cap');
  var pMeta = document.getElementById('program-meta');

  function goProgram(i) {
    var el = pSlides[i];
    if (el && el.dataset.lazyBg && !el.style.backgroundImage) {
      el.style.backgroundImage = 'url(' + el.dataset.lazyBg + ')';
    }
    pSlides.forEach(function(s, j) { s.style.opacity = j === i ? '1' : '0'; });
    pDots.forEach(function(d, j) { d.classList.toggle('program-slider__dot--active', j === i); });
    if (pCounter) pCounter.textContent = String(i + 1).padStart(2, '0') + ' / ' + String(pTotal).padStart(2, '0');
    if (pCap) pCap.textContent = '"' + programSlides[i].cap + '"';
    if (pMeta) pMeta.textContent = programSlides[i].meta;
    pIdx = i;
  }

  pDots.forEach(function(d) { d.addEventListener('click', function() { goProgram(Number(d.dataset.programDot)); }); });
  var pPaused = false;
  var pSlider = document.getElementById('program-slider');
  pSlider.addEventListener('mouseenter', function() { pPaused = true; });
  pSlider.addEventListener('mouseleave', function() { pPaused = false; });
  setInterval(function() { if (!pPaused) goProgram((pIdx + 1) % pTotal); }, 3000);
</script>
