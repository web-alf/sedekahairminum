---
import IndonesiaMap from './IndonesiaMap';

interface Props {
  points: Array<{ lng: number; lat: number; name: string; alamat: string; galon: number }>;
}
const { points } = Astro.props;
---

<section class="section map-section">
  <div class="container">
    <div class="section-head section-head--center fade-up">
      <span class="eyebrow">Jangkauan Nasional</span>
      <h2 style="margin-top:18px">Peta Penyebaran <em class="italic-serif">Sedekah Air Minum</em></h2>
      <p class="section-head__intro" style="text-align:center;margin:16px auto 0">
        Untuk saat ini Distribusi Air Minum Gratis kami fokuskan di Daerah Istimewa Yogyakarta (DIY). Tujuannya agar distribusi dapat berjalan lebih optimal, terpantau, dan merata. Adapun penerima manfaat dalam program ini adalah pondok pesantren dan lembaga yang membutuhkan sebagai bentuk dukungan terhadap kebutuhan air minum para santri dan lembaga masyarakat lainnya.
      </p>
    </div>
    <div class="fade-up map-wrapper" id="map-wrapper">
      <IndonesiaMap points={points} client:only="react" />
    </div>
    <div class="map-legend fade-up">
      <span class="map-legend__item"><span class="map-legend__dot" style="background:#5ee4f0"></span> Lokasi penerima manfaat</span>
      <span class="map-legend__item" style="margin-left:auto;color:var(--ink-dim)">Data 2026 · 19 lembaga · 298 galon/distribusi · Kab. Gunung Kidul</span>
    </div>
  </div>
</section>

<style>
  .map-wrapper {
    border-radius: var(--r-lg);
    overflow: hidden;
    border: 1px solid var(--border);
    aspect-ratio: 21 / 9;
    background: var(--bg-elev);
    position: relative;
  }
  @media (max-width: 640px) {
    .map-wrapper { aspect-ratio: 4 / 3; }
  }
</style>
