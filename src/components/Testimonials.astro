---
interface Props { testimonials: { body: string; name: string; role: string; photo: string | null }[] }
const { testimonials } = Astro.props;
---

<section class="section" style="background:var(--surface);border-block:1px solid var(--border)">
  <div class="container">
    <div class="section-head section-head--center fade-up">
      <span class="eyebrow">Penerima Manfaat</span>
      <h2 style="margin-top:18px">Suara dari <em class="italic-serif">mereka</em></h2>
    </div>
    <div class="testimonial-rail">
      {testimonials.map((t, i) => (
        <article class="testimonial fade-up" style={`transition-delay:${i * 80}ms`}>
          <div class="testimonial__author">
            <img src={t.photo} alt={t.name} class="testimonial__photo" loading="lazy" />
            <div>
              <div class="testimonial__name">{t.name}</div>
              {t.role && <div class="testimonial__role">{t.role}</div>}
            </div>
          </div>
          <blockquote class="testimonial__body">{t.body}</blockquote>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonial__photo {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center 20%;
    border: 2px solid var(--border-strong);
    flex-shrink: 0;
  }
</style>
