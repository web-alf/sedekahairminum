---
const currentPath = Astro.url.pathname;
const links = [
  { href: '/', label: 'Beranda' },
  { href: '/tentang', label: 'Tentang Kami' },
  { href: '/penerima', label: 'Penerima Manfaat' },
  { href: '/kontak', label: 'Kontak' },
];
---

<header class="nav" id="main-nav">
  <div class="container">
    <div class="nav__inner">
      <a href="/" class="nav__brand" aria-label="Sedekah Air Minum — Beranda">
        <img src="/assets/logo-0.png" alt="Sedekah Air Minum" class="nav__logo" />
      </a>

      <nav aria-label="Navigasi utama">
        <ul class="nav__links">
          {links.map(l => (
            <li>
              <a
                href={l.href}
                class:list={['nav__link', { 'nav__link--active': currentPath === l.href || (l.href !== '/' && currentPath.startsWith(l.href)) }]}
              >{l.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="nav__actions">
        <button class="theme-toggle nav__desktop-only" id="theme-toggle-desktop" aria-label="Ganti tema">
          <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
          </svg>
          <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
        <a href="/kontak" class="btn btn--primary btn--sm nav__desktop-only">
          Sedekah Sekarang
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        <button class="nav__hamburger" id="mobile-toggle" aria-label="Menu navigasi" aria-expanded="false">
          <span class="nav__hamburger-line"></span>
          <span class="nav__hamburger-line"></span>
          <span class="nav__hamburger-line"></span>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- Overlay -->
<div class="sidebar-overlay" id="sidebar-overlay"></div>

<!-- Sidebar -->
<aside class="sidebar" id="sidebar" aria-hidden="true">
  <div class="sidebar__inner">
    <div class="sidebar__header">
      <img src="/assets/logo-0.png" alt="Sedekah Air Minum" class="sidebar__logo" />
      <button class="sidebar__close" id="sidebar-close" aria-label="Tutup menu">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
      </button>
    </div>

    <nav class="sidebar__nav">
      {links.map(l => (
        <a
          href={l.href}
          class:list={['sidebar__link', { 'sidebar__link--active': currentPath === l.href || (l.href !== '/' && currentPath.startsWith(l.href)) }]}
        >{l.label}</a>
      ))}
    </nav>

    <div class="sidebar__divider"></div>

    <div class="sidebar__actions">
      <button class="sidebar__theme-row" id="theme-toggle-mobile" aria-label="Ganti tema">
        <span class="sidebar__theme-icon">
          <svg class="icon-sun" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
          </svg>
          <svg class="icon-moon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </span>
        <span class="sidebar__theme-label" id="theme-label">Mode Terang</span>
      </button>

      <a href="/kontak" class="btn btn--primary sidebar__cta">
        Sedekah Sekarang
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>

    <div class="sidebar__footer">
      <p>Gerakan Wakaf Air Bersih</p>
      <a href="https://wa.me/6285319480974?text=Assalamu%27alaikum%2C%20saya%20ingin%20bertanya%20tentang%20program%20Sedekah%20Air%20Minum." target="_blank" rel="noopener noreferrer">+62 853-1948-0974</a>
    </div>
  </div>
</aside>

<style>
  /* Icon toggle with animation */
  .icon-sun, .icon-moon {
    position: absolute;
    transition: transform 0.4s var(--ease-out), opacity 0.4s var(--ease-out);
  }
  .icon-sun {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }
  .icon-moon {
    opacity: 0;
    transform: rotate(-90deg) scale(0.5);
  }
  :global([data-theme="light"]) .icon-sun {
    opacity: 0;
    transform: rotate(90deg) scale(0.5);
  }
  :global([data-theme="light"]) .icon-moon {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }

  .nav__logo { height: 44px; width: auto; object-fit: contain; }
  .nav__desktop-only { display: flex; }

  /* ── Hamburger ── */
  .nav__hamburger {
    display: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--border-strong);
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 5px;
    padding: 10px;
    cursor: pointer;
    position: relative;
    z-index: 102;
  }
  .nav__hamburger-line {
    display: block;
    width: 18px;
    height: 1.5px;
    background: var(--ink);
    border-radius: 2px;
    transition: transform 0.35s var(--ease-out), opacity 0.25s var(--ease-out);
    transform-origin: center;
  }
  :global(.sidebar-open) .nav__hamburger-line:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  :global(.sidebar-open) .nav__hamburger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  :global(.sidebar-open) .nav__hamburger-line:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* ── Overlay ── */
  .sidebar-overlay {
    position: fixed;
    inset: 0;
    z-index: 150;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s var(--ease-out), visibility 0.4s;
  }
  :global(.sidebar-open) .sidebar-overlay {
    opacity: 1;
    visibility: visible;
  }

  /* ── Sidebar ── */
  .sidebar {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(320px, 85vw);
    z-index: 200;
    background: var(--bg-elev);
    border-left: 1px solid var(--border);
    transform: translateX(100%);
    transition: transform 0.4s var(--ease-out);
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }
  :global(.sidebar-open) .sidebar {
    transform: translateX(0);
  }
  .sidebar__inner {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    padding: 24px;
  }
  .sidebar__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 32px;
  }
  .sidebar__logo {
    height: 36px;
    width: auto;
  }
  .sidebar__close {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid var(--border-strong);
    display: grid;
    place-items: center;
    color: var(--ink-muted);
    transition: all 0.25s var(--ease-out);
  }
  .sidebar__close:hover { border-color: var(--aqua); color: var(--aqua); }

  .sidebar__nav {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .sidebar__link {
    display: flex;
    align-items: center;
    padding: 14px 16px;
    font-size: 15px;
    font-weight: 500;
    color: var(--ink-muted);
    border-radius: var(--r-sm);
    transition: color 0.25s, background 0.25s;
  }
  .sidebar__link:hover {
    color: var(--ink);
    background: var(--surface);
  }
  .sidebar__link--active {
    color: var(--aqua);
    background: color-mix(in srgb, var(--aqua) 8%, transparent);
  }

  .sidebar__divider {
    height: 1px;
    background: var(--border);
    margin: 24px 0;
  }

  .sidebar__actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .sidebar__theme-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 12px 16px;
    border-radius: var(--r-sm);
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--ink-muted);
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: border-color 0.25s, color 0.25s;
    width: 100%;
  }
  .sidebar__theme-row:hover { border-color: var(--aqua); color: var(--aqua); }
  .sidebar__theme-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    width: 18px;
    height: 18px;
  }
  .sidebar__cta {
    width: 100%;
    justify-content: center;
  }

  .sidebar__footer {
    margin-top: auto;
    padding-top: 32px;
    font-size: 12px;
    color: var(--ink-dim);
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .sidebar__footer a { color: var(--aqua); }

  /* Nav over hero (not scrolled) — force light colors for visibility */
  :global([data-theme="light"]) :global(.nav:not(.nav--scrolled)) .nav__hamburger {
    border-color: rgba(255,255,255,0.4);
  }
  :global([data-theme="light"]) :global(.nav:not(.nav--scrolled)) .nav__hamburger-line {
    background: #fff;
  }
  :global([data-theme="light"]) :global(.nav:not(.nav--scrolled)) .nav__desktop-only.theme-toggle {
    border-color: rgba(255,255,255,0.4);
    color: #fff;
  }
  :global([data-theme="light"]) :global(.nav:not(.nav--scrolled)) :global(.nav__link) {
    color: rgba(255,255,255,0.7);
  }
  :global([data-theme="light"]) :global(.nav:not(.nav--scrolled)) :global(.nav__link:hover) {
    color: #fff;
  }
  :global([data-theme="light"]) :global(.nav:not(.nav--scrolled)) :global(.nav__link--active) {
    color: #5ee4f0;
  }

  @media (max-width: 1080px) {
    .nav__desktop-only { display: none !important; }
    .nav__hamburger { display: inline-flex; }
  }
</style>

<script>
  const nav = document.getElementById('main-nav')!;
  const hamburger = document.getElementById('mobile-toggle')!;
  const sidebar = document.getElementById('sidebar')!;
  const overlay = document.getElementById('sidebar-overlay')!;
  const closeBtn = document.getElementById('sidebar-close')!;
  const themeLabel = document.getElementById('theme-label')!;

  function updateThemeLabel() {
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    themeLabel.textContent = isDark ? 'Mode Terang' : 'Mode Gelap';
  }
  updateThemeLabel();

  function openSidebar() {
    document.body.classList.add('sidebar-open');
    document.body.style.overflow = 'hidden';
    sidebar.setAttribute('aria-hidden', 'false');
    hamburger.setAttribute('aria-expanded', 'true');
    closeBtn.focus();
  }

  function closeSidebar() {
    document.body.classList.remove('sidebar-open');
    document.body.style.overflow = '';
    sidebar.setAttribute('aria-hidden', 'true');
    hamburger.setAttribute('aria-expanded', 'false');
    hamburger.focus();
  }

  hamburger.addEventListener('click', () => {
    document.body.classList.contains('sidebar-open') ? closeSidebar() : openSidebar();
  });
  overlay.addEventListener('click', closeSidebar);
  closeBtn.addEventListener('click', closeSidebar);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && document.body.classList.contains('sidebar-open')) closeSidebar();
    if (e.key === 'Tab' && document.body.classList.contains('sidebar-open')) {
      const focusable = sidebar.querySelectorAll('a, button, input, [tabindex]:not([tabindex="-1"])');
      const first = focusable[0] as HTMLElement;
      const last = focusable[focusable.length - 1] as HTMLElement;
      if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
      else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
    }
  });

  sidebar.querySelectorAll('.sidebar__link').forEach(link => {
    link.addEventListener('click', closeSidebar);
  });

  function toggleTheme() {
    const html = document.documentElement;
    html.classList.add('theme-transitioning');
    const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    html.classList.toggle('dark', next === 'dark');
    localStorage.setItem('sam-theme', next);
    updateThemeLabel();
    setTimeout(() => html.classList.remove('theme-transitioning'), 600);
  }

  document.getElementById('theme-toggle-desktop')?.addEventListener('click', toggleTheme);
  document.getElementById('theme-toggle-mobile')?.addEventListener('click', toggleTheme);

  window.addEventListener('scroll', () => {
    nav.classList.toggle('nav--scrolled', window.scrollY > 30);
  }, { passive: true });
</script>
