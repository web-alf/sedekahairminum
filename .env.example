# ─── Supabase ────────────────────────────────────────────────────────────────
# Public — inlined into the client bundle at build time. The anon key is safe to
# expose; Row Level Security governs what it can read/write.
PUBLIC_SUPABASE_URL=https://YOUR_REF.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Server-only — read at runtime from Astro.locals.runtime.env (Cloudflare).
# NEVER prefix these with PUBLIC_ and never import them into a client island.
SUPABASE_URL=https://YOUR_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # bypasses RLS — keep secret

# ─── Cloudflare ──────────────────────────────────────────────────────────────
# Deploy hook that triggers a rebuild of the static marketing pages after a
# CMS edit. Create under Workers & Pages → your project → Settings → Deploy hooks.
CF_DEPLOY_HOOK_URL=

# Shared secret required in the X-Cron-Secret header to call /api/heartbeat.
# Generate with: openssl rand -hex 32
CRON_SECRET=
